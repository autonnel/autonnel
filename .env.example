# Development environment for the autonnel package repo.
# Consumer deployments should use autonnel-deploy-example and its .env.example.
#
# Provider configuration (S3 storage, payment, email, ecommerce, LLM, ads) is
# NOT set via env — it lives in the admin UI under Settings, stored in the DB.

# Required — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/autonnel"

# Hostname(s) the admin UI is served on. Comma-separated; each entry may use
# '*' as a single-label wildcard ("*.example.com"). Every non-matching host
# serves the storefront. Local dev: "localhost".
ADMIN_DOMAIN="localhost"

# Required in production (any NODE_ENV other than development/test).
# Signs session/checkout cookies. Generate: openssl rand -hex 32
AUTH_SESSION_SECRET=""

# Required in production. Encrypts provider credentials (payment/email/
# ecommerce) at rest in the database. Generate: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=""

# Shared secret protecting the HTTP cron endpoints (recommended in production)
CRON_KEY=""

# Optional
LOG_LEVEL="info"                # debug | info | warn | error
DEFAULT_CURRENCY="USD"          # storefront fallback currency
PORT="3000"

# Optional — Redis cache. Falls back to in-memory when unset; Cloudflare
# Workers deployments use KV instead.
REDIS_URL=""

# Cloudflare Workers (dev:cf / preview:cf / deploy:cf). Create the resources:
#   wrangler kv namespace create CACHE_KV
#   wrangler hyperdrive create autonnel-db --connection-string="postgresql://..."
CF_WORKER_NAME=""
CF_KV_NAMESPACE_ID=""
CF_HYPERDRIVE_CONFIG_ID=""
# Local wrangler dev only: direct Postgres connection for Hyperdrive emulation
CF_HYPERDRIVE_LOCAL_CONNECTION_STRING=""
