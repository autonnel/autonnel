---
import { getCurrentTenantId } from '@/lib/tenant';
import { getHook } from '@/lib/hooks';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, canAccessPermissionsPageAsync, FEATURES } from '@/lib/rbac';
import { WORKSPACE_NAV, SETTINGS_NAV, type NavGroup } from '@/lib/dashboard/nav';
import { loadSystemHealth } from '@/lib/dashboard/system-health';
import { getNavHidden, getSidebarSystemAppend, getUiSlotList } from '@/lib/plugins/registry';
import { svg } from './sidebar-icons';
import { decorateGroup, type VisibleChild, type VisibleItem } from './sidebar-nav';
import SidebarNavItem from './SidebarNavItem.astro';

interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;

const auth = await checkAuth(Astro);
const userId = auth.user?.id ?? '';
const userProviderId = auth.user?.providerId ?? '';

const tenantId = getCurrentTenantId();
let tenantIds: string[] = [tenantId];
const getAllTenantIds = getHook('getAllTenantIds');
if (getAllTenantIds) {
  try {
    const ids = await getAllTenantIds();
    if (ids.length > 0) tenantIds = ids;
  } catch {
  }
}
const isMultiTenant = tenantIds.length > 1;

const isPermissionsAdmin = userId
  ? await canAccessPermissionsPageAsync(userId, userProviderId)
  : false;

const buildVersion = process.env.npm_package_version || '0.1.0';

const health = await loadSystemHealth().catch(() => ({ status: 'healthy' as const, reason: null }));

const featureChecks = userId
  ? await Promise.all([
      userHasFeature(userId, FEATURES.PAGES),
      userHasFeature(userId, FEATURES.FUNNELS),
      userHasFeature(userId, FEATURES.ORDERS),
      userHasFeature(userId, FEATURES.ORDERS_EMAILS),
      userHasFeature(userId, FEATURES.PAYMENT),
      userHasFeature(userId, FEATURES.PAYMENT_REFUND),
      userHasFeature(userId, FEATURES.MARKETING),
      userHasFeature(userId, FEATURES.ANALYTICS),
      userHasFeature(userId, FEATURES.SETTINGS),
    ])
  : Array<boolean>(9).fill(true);

const [
  canPages,
  canFunnels,
  canOrders,
  canOrdersEmails,
  canPayment,
  canPaymentRefunds,
  canMarketing,
  canAnalytics,
  canSettings,
] = featureChecks;

const hiddenIds = new Set(getNavHidden());

const VISIBILITY: Record<string, boolean> = {
  overview: true,
  funnels: canFunnels || canPages,
  'funnels.funnels': canFunnels,
  'funnels.pages': canPages,
  orders: canOrders || canOrdersEmails,
  'orders.orders': canOrders,
  'orders.emails': canOrdersEmails,
  payment: canPayment || canPaymentRefunds,
  'payment.payment': canPayment,
  'payment.transactions': canPaymentRefunds,
  marketing: canMarketing,
  analytics: canAnalytics,
  'settings.branding': canSettings,
  'settings.localization': canSettings,
  'settings.domains': canSettings,
  'settings.custom-code': canSettings,
  'settings.storage': canSettings,
  'settings.llm': canSettings,
  'settings.notifications': canSettings,
  'settings.ai-conversion-analysis': canSettings,
  'settings.integrations': canSettings,
  'settings.email': canSettings,
  'settings.email-templates': canSettings,
  'settings.ecommerce': canSettings,
  'settings.recall': canSettings,
  'settings.maintenance': canSettings,
  'settings.coupons': canSettings,
  'settings.users': canSettings,
  'settings.permissions': !!isPermissionsAdmin,
  'settings.api-keys': canSettings,
  'settings.logs': canSettings,
};

const settingsAppend: VisibleChild[] = getUiSlotList('settings.menu.append').map((item) => ({
  id: item.id,
  label: item.label,
  href: item.href,
  visible: canSettings && !hiddenIds.has(item.id),
}));

const decorate = (group: NavGroup): VisibleItem =>
  decorateGroup(group, VISIBILITY, hiddenIds, settingsAppend);

const workspaceItems: VisibleItem[] = WORKSPACE_NAV.map(decorate);
const systemItems: VisibleItem[] = [decorate(SETTINGS_NAV)];

const sidebarSystemAppend = getSidebarSystemAppend().filter((item) => !hiddenIds.has(item.id));

const resourceItems = [
  { id: 'docs', label: 'Documentation', href: 'https://github.com/autonnel/autonnel#readme', external: true },
  { id: 'changelog', label: 'Changelog', href: 'https://github.com/autonnel/autonnel/releases', external: true },
];

const activeTop = activeNav ? activeNav.split('.')[0] : '';
const expandedFromActive = activeNav && activeNav.includes('.') ? activeTop : '';
---

<aside
  class="fixed left-0 top-0 bottom-0 w-[240px] bg-ds-surface2 border-r border-ds-line flex flex-col font-ds-sans text-ds-ink z-30"
  aria-label="Primary navigation"
  data-active-nav={activeNav}
  data-active-top={activeTop}
  data-expanded-from-active={expandedFromActive}
>
  <div class="px-4 pt-4 pb-3 flex items-center gap-2.5">
    <svg viewBox="0 0 100 100" class="w-6 h-6 rounded-[6px] shrink-0" aria-hidden="true">
      <rect x="2" y="2" width="96" height="96" rx="18" fill="#0F0F10"/>
      <rect x="20" y="16.85" width="60" height="9" rx="1.5" fill="#FAF7F2"/>
      <rect x="32" y="36.85" width="36" height="9" rx="1.5" fill="#FAF7F2"/>
      <rect x="44" y="56.85" width="12" height="9" rx="1.5" fill="#FAF7F2"/>
      <rect x="46.5" y="76.85" width="7" height="6.3" rx="1.5" fill="#FF5A1F"/>
    </svg>
    <span class="text-[14px] font-semibold tracking-tight">Autonnel</span>
  </div>

  {isMultiTenant && (
    <div class="px-3 pb-3">
      <details class="group relative">
        <summary
          class="flex items-center justify-between gap-2 cursor-pointer list-none bg-ds-card border border-ds-line rounded-[8px] px-2.5 py-1.5 text-[12.5px] hover:border-ds-linehi"
        >
          <span class="flex items-center gap-2 min-w-0">
            <span class="w-4 h-4 rounded-[4px] bg-ds-accent shrink-0" aria-hidden="true"></span>
            <span class="truncate font-medium">{tenantId}</span>
          </span>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3.5 h-3.5 text-ds-muted shrink-0" aria-hidden="true">
            <path d="M4 6l4 4l4-4" />
          </svg>
        </summary>
        <div class="absolute left-0 right-0 mt-1 bg-ds-card border border-ds-line rounded-[8px] shadow-[0_4px_12px_rgba(17,24,39,.06)] py-1 z-20">
          {tenantIds.map((id) => (
            <div class="px-2.5 py-1.5 text-[12.5px] text-ds-ink flex items-center gap-2">
              <span class={`w-1.5 h-1.5 rounded-full ${id === tenantId ? 'bg-ds-accent' : 'bg-ds-faint'}`} aria-hidden="true"></span>
              <span class="truncate">{id}</span>
            </div>
          ))}
        </div>
      </details>
    </div>
  )}

  <nav class="flex-1 overflow-y-auto px-3 pb-3 flex flex-col gap-4 min-h-0">
    <div>
      <div class="px-2 pb-1.5 text-[10.5px] uppercase tracking-[0.06em] text-ds-faint font-medium">
        Manage
      </div>
      <div class="flex flex-col gap-0.5">
        {workspaceItems.filter((i) => i.visible).map((item) => (
          <SidebarNavItem item={item} activeNav={activeNav} activeTop={activeTop} />
        ))}
      </div>
    </div>

    <div>
      <div class="px-2 pb-1.5 text-[10.5px] uppercase tracking-[0.06em] text-ds-faint font-medium">
        System
      </div>
      <div class="flex flex-col gap-0.5">
        {sidebarSystemAppend.map((item) => {
          const isActive = activeNav === item.id;
          const cls = isActive
            ? 'flex items-center gap-2 text-[13.5px] rounded-md px-2.5 py-[7px] bg-ds-card border border-ds-line shadow-[0_1px_2px_rgba(17,24,39,.04)] text-ds-ink no-underline'
            : 'flex items-center gap-2 text-[13.5px] rounded-md px-2.5 py-[7px] border border-transparent text-[#374151] hover:bg-[#F3F4F6] hover:text-ds-ink no-underline';
          return (
            <a href={item.href} class={cls} aria-current={isActive ? 'page' : undefined}>
              <span class="shrink-0 text-ds-muted" set:html={svg(item.icon || item.id)} aria-hidden="true"></span>
              <span class="flex-1 truncate">{item.label}</span>
            </a>
          );
        })}
        {systemItems.filter((i) => i.visible).map((item) => (
          <SidebarNavItem item={item} activeNav={activeNav} activeTop={activeTop} />
        ))}
      </div>
    </div>

    <div>
      <div class="px-2 pb-1.5 text-[10.5px] uppercase tracking-[0.06em] text-ds-faint font-medium">
        Resources
      </div>
      <div class="flex flex-col gap-0.5">
        {resourceItems.map((item) => (
          <a
            href={item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener noreferrer' : undefined}
            class="flex items-center gap-2 text-[13.5px] rounded-md px-2.5 py-[7px] border border-transparent text-[#374151] hover:bg-[#F3F4F6] hover:text-ds-ink no-underline"
          >
            <span class="shrink-0 text-ds-muted" set:html={svg(item.id)} aria-hidden="true"></span>
            <span class="flex-1 truncate">{item.label}</span>
            {item.external && (
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3 h-3 text-ds-faint" aria-hidden="true">
                <path d="M6 3h7v7M13 3L6.5 9.5M3 6v7h7" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <div class="p-3 border-t border-ds-line">
    <a
      href="/settings/logs"
      class="block bg-ds-card border border-ds-line rounded-[8px] px-3 py-2.5 no-underline hover:border-ds-linehi"
    >
      <div class="text-[12px] font-semibold text-ds-ink mb-1.5">System</div>
      {health.status === 'healthy' ? (
        <div class="flex items-center gap-1.5 text-[11.5px] text-ds-slate mb-2">
          <span
            class="inline-block w-[7px] h-[7px] rounded-full shrink-0 animate-softblink"
            style="background-color: #16A34A; box-shadow: 0 0 0 3px rgba(22,163,74,0.12);"
            aria-hidden="true"
          ></span>
          <span>Healthy</span>
        </div>
      ) : (
        <>
          <div class="flex items-center gap-1.5 text-[11.5px] text-ds-warnText">
            <span
              class="inline-block w-[7px] h-[7px] rounded-full shrink-0"
              style="background-color: #D97706; box-shadow: 0 0 0 3px rgba(217,119,6,0.12);"
              aria-hidden="true"
            ></span>
            <span>Degraded</span>
          </div>
          {health.reason && (
            <div class="text-[11px] text-ds-warnText mb-2 truncate" title={health.reason}>{health.reason}</div>
          )}
        </>
      )}
    </a>
  </div>
</aside>

<script is:inline>
  (function () {
    const STORAGE_KEY = 'autonnel:sidebar:expanded';
    const DEFAULT_EXPANDED = ['funnels', 'orders', 'payment', 'settings'];
    const aside = document.querySelector('aside[data-active-nav]');
    if (!aside) return;
    const expandedFromActive = aside.getAttribute('data-expanded-from-active') || '';

    let stored = null;
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        if (Array.isArray(parsed)) stored = parsed.filter((x) => typeof x === 'string');
      }
    } catch (e) {
      stored = null;
    }

    const expanded = new Set(stored === null ? DEFAULT_EXPANDED : stored);
    if (expandedFromActive) expanded.add(expandedFromActive);

    function persist() {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(expanded)));
      } catch (e) {
      }
    }

    const groups = aside.querySelectorAll('.autonnel-sidebar-group');
    groups.forEach((group) => {
      const id = group.getAttribute('data-group-id') || '';
      const toggle = group.querySelector('.autonnel-sidebar-toggle');
      const children = group.querySelector('.autonnel-sidebar-children');
      const caret = group.querySelector('.autonnel-sidebar-caret');
      if (!toggle || !children) return;

      function applyState() {
        const isOpen = expanded.has(id);
        if (isOpen) {
          children.classList.remove('hidden');
          if (caret) caret.style.transform = 'rotate(180deg)';
          toggle.setAttribute('aria-expanded', 'true');
        } else {
          children.classList.add('hidden');
          if (caret) caret.style.transform = '';
          toggle.setAttribute('aria-expanded', 'false');
        }
      }

      applyState();

      toggle.addEventListener('click', function () {
        if (expanded.has(id)) expanded.delete(id);
        else expanded.add(id);
        persist();
        applyState();
      });
    });

    persist();
  })();

  (function () {
    const KEY = 'autonnel:sidebar:scroll';
    const nav = document.querySelector('aside[data-active-nav] nav');
    if (!nav) return;
    try {
      const saved = sessionStorage.getItem(KEY);
      if (saved) nav.scrollTop = parseInt(saved, 10) || 0;
    } catch (e) {}
    let raf = 0;
    nav.addEventListener('scroll', function () {
      if (raf) return;
      raf = requestAnimationFrame(function () {
        try {
          sessionStorage.setItem(KEY, String(nav.scrollTop));
        } catch (e) {}
        raf = 0;
      });
    });
  })();
</script>
