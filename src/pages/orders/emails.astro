---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, FEATURES } from '@/lib/rbac';
import { loadEmailsMonitorData, EMPTY_EMAIL_KPI } from '@/lib/dashboard/orders-data';
import {
  paginate,
  pageNumbers,
  statusBadgeClasses,
  prettyTemplateType,
} from '@/lib/dashboard/orders-helpers';
import { computeDelta, formatNumber, relativeTime } from '@/lib/dashboard/overview-helpers';
import { formatDateTimeInTimezone, timezoneLabel, DEFAULT_TIMEZONE } from '@/lib/constants/timezone';
import { getSiteTimezone } from '@/lib/config/keys';
import { cn } from '@/lib/utils';
import { dsFieldClass, dsSelectClass } from '@/components/primitives/field-styles';
import Stat from '@/components/primitives/ds/Stat';

const auth = await checkAuth(Astro);
if (!auth.authenticated || !auth.user) {
  return Astro.redirect('/login');
}
const hasAccess = await userHasFeature(auth.user.id, FEATURES.ORDERS_EMAILS);
if (!hasAccess) {
  return Astro.redirect('/orders');
}

const url = new URL(Astro.request.url);
const search = (url.searchParams.get('q') || '').trim().toLowerCase();
const statusFilter = url.searchParams.get('status') || '';
const typeFilter = url.searchParams.get('type') || '';
const dateFromStr = url.searchParams.get('from') || '';
const dateToStr = url.searchParams.get('to') || '';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10) || 1);
const perPage = 30;

const now = new Date();
const tz = await getSiteTimezone().catch(() => DEFAULT_TIMEZONE);
let data;
try {
  data = await loadEmailsMonitorData(now);
} catch {
  data = { rows: [], templateTypes: [], kpi: EMPTY_EMAIL_KPI };
}

const dateFrom = dateFromStr ? new Date(dateFromStr) : null;
const dateTo = dateToStr ? new Date(dateToStr + 'T23:59:59') : null;
const fromTs = dateFrom ? dateFrom.getTime() : null;
const toTs = dateTo ? dateTo.getTime() : null;

const filtered = data.rows.filter((r) => {
  if (statusFilter && r.status !== statusFilter) return false;
  if (typeFilter && r.templateKey !== typeFilter) return false;
  const ts = r.createdAt.getTime();
  if (fromTs !== null && ts < fromTs) return false;
  if (toTs !== null && ts > toTs) return false;
  if (search) {
    const recipient = r.recipient.toLowerCase();
    const subject = (r.subject || '').toLowerCase();
    if (!recipient.includes(search) && !subject.includes(search)) return false;
  }
  return true;
});

const paged = paginate(filtered, page, perPage);

const pendingDelta = computeDelta(data.kpi.pending24h, data.kpi.pendingPrev24h, { invertTone: true });
const sentDelta = computeDelta(data.kpi.sent24h, data.kpi.sentPrev24h);
const failedDelta = computeDelta(data.kpi.failed24h, data.kpi.failedPrev24h, { invertTone: true });

const statusOptions = ['PENDING', 'SENDING', 'SENT', 'FAILED', 'RETRYING'];

function pageHref(p: number): string {
  const params = new URLSearchParams(url.searchParams);
  params.set('page', String(p));
  return `/orders/emails?${params.toString()}`;
}

---

<DashboardLayout
  title="Email queue"
  activeNav="orders.emails"
>
  <div class="grid grid-cols-12 gap-5">
    <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)] px-6 py-5">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <Stat
          client:load
          label="Pending (24h)"
          value={formatNumber(data.kpi.pending24h)}
          delta={{ ...pendingDelta, context: 'vs prev 24h' }}
        />
        <Stat
          client:load
          label="Sent (24h)"
          value={formatNumber(data.kpi.sent24h)}
          delta={{ ...sentDelta, context: 'vs prev 24h' }}
        />
        <Stat
          client:load
          label="Failed (24h)"
          value={formatNumber(data.kpi.failed24h)}
          delta={{ ...failedDelta, context: 'vs prev 24h' }}
        />
        <Stat
          client:load
          label="Avg attempts"
          value={data.kpi.avgAttempts.toFixed(2)}
        />
      </div>
    </div>

    <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)]">
      <div class="px-6 pt-5 pb-4 flex items-start justify-between gap-4 flex-wrap">
        <div class="min-w-0">
          <div class="text-[14px] font-semibold text-ds-ink">Email queue</div>
          <div class="text-[12.5px] text-ds-muted mt-0.5">
            <span class="font-ds-mono tabular">{paged.total}</span> matching · showing
            <span class="font-ds-mono tabular"> {paged.items.length}</span>
          </div>
        </div>
        <form method="get" action="/orders/emails" class="flex items-center gap-2 shrink-0 flex-wrap">
          <input
            type="text"
            name="q"
            value={url.searchParams.get('q') || ''}
            placeholder="Order # or email…"
            class={cn(dsFieldClass, "h-8 w-[220px]")}
          />
          <select
            name="type"
            class={cn(dsSelectClass, "h-8 w-auto")}
          >
            <option value="">All types</option>
            {data.templateTypes.map((t) => (
              <option value={t} selected={typeFilter === t}>{prettyTemplateType(t)}</option>
            ))}
          </select>
          <select
            name="status"
            class={cn(dsSelectClass, "h-8 w-auto")}
          >
            <option value="">All status</option>
            {statusOptions.map((s) => (
              <option value={s} selected={statusFilter === s}>{s}</option>
            ))}
          </select>
          <input
            type="date"
            name="from"
            value={dateFromStr}
            class={cn(dsFieldClass, "h-8 w-auto")}
          />
          <input
            type="date"
            name="to"
            value={dateToStr}
            class={cn(dsFieldClass, "h-8 w-auto")}
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB]"
          >
            Filter
          </button>
        </form>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead class="bg-ds-surface2 border-b border-ds-line">
            <tr>
              <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Status</th>
              <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Recipient</th>
              <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Template</th>
              <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">Attempts</th>
              <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Last error</th>
              <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">Created</th>
            </tr>
          </thead>
          <tbody>
            {paged.items.length === 0 ? (
              <tr>
                <td colspan="6" class="px-4 py-12 text-center text-[13px] text-ds-muted">
                  No emails match the current filters.
                </td>
              </tr>
            ) : (
              paged.items.map((row) => (
                <tr class="hover:bg-ds-surface2 transition-colors">
                  <td class="px-4 py-3 border-b border-[#F3F4F6]">
                    <span class={`inline-flex items-center gap-1.5 rounded-full border px-2 py-[3px] text-[11.5px] font-medium leading-none ${statusBadgeClasses(row.status)}`}>
                      {row.status}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] font-ds-mono tabular truncate max-w-[220px]" title={row.recipient}>
                    {row.recipient}
                  </td>
                  <td class="px-4 py-3 text-[13px] text-ds-ink border-b border-[#F3F4F6]">
                    <div class="text-[13px] text-ds-ink">{prettyTemplateType(row.templateKey)}</div>
                    {row.subject && (
                      <div class="text-[11.5px] text-ds-muted truncate max-w-[280px]" title={row.subject}>{row.subject}</div>
                    )}
                  </td>
                  <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] text-right font-ds-mono tabular">
                    {row.attemptCount}
                  </td>
                  <td class="px-4 py-3 text-[12px] border-b border-[#F3F4F6]">
                    {row.lastError ? (
                      <span class="text-ds-bad truncate inline-block max-w-[260px]" title={row.lastError}>
                        {row.lastError}
                      </span>
                    ) : (
                      <span class="text-ds-faint">—</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-[12.5px] text-ds-muted border-b border-[#F3F4F6] text-right font-ds-mono tabular whitespace-nowrap" title={`${formatDateTimeInTimezone(row.createdAt, tz)} ${timezoneLabel(tz)}`}>
                    {relativeTime(row.createdAt, now)}
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>

      {paged.totalPages > 1 && (
        <div class="px-6 py-3 flex items-center justify-between border-t border-ds-line bg-ds-surface2 text-[12px] text-ds-muted">
          <div>
            Showing
            <span class="font-ds-mono tabular"> {(paged.page - 1) * perPage + 1}</span>
            –
            <span class="font-ds-mono tabular">{(paged.page - 1) * perPage + paged.items.length}</span>
            of
            <span class="font-ds-mono tabular"> {paged.total}</span>
          </div>
          <div class="flex items-center gap-1">
            {paged.page > 1 ? (
              <a href={pageHref(paged.page - 1)} class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline">Prev</a>
            ) : (
              <span class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-faint">Prev</span>
            )}
            {pageNumbers(paged.page, paged.totalPages).map((p) =>
              p === '...' ? (
                <span class="px-2 text-ds-faint text-[12px]">…</span>
              ) : p === paged.page ? (
                <span class="inline-flex items-center justify-center rounded-[6px] h-7 min-w-[28px] px-2 text-[12px] bg-ds-ink text-ds-card font-ds-mono tabular">{p}</span>
              ) : (
                <a href={pageHref(p as number)} class="inline-flex items-center justify-center rounded-[6px] h-7 min-w-[28px] px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline font-ds-mono tabular">{p}</a>
              ),
            )}
            {paged.page < paged.totalPages ? (
              <a href={pageHref(paged.page + 1)} class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline">Next</a>
            ) : (
              <span class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-faint">Next</span>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</DashboardLayout>
