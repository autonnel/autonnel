---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, FEATURES } from '@/lib/rbac';
import { loadOrdersListData, EMPTY_ORDER_KPI } from '@/lib/dashboard/orders-data';
import {
  filterOrderRows,
  paginate,
  pageNumbers,
  statusBadgeClasses,
  formatMoney,
} from '@/lib/dashboard/orders-helpers';
import { computeDelta, formatNumber, relativeTime } from '@/lib/dashboard/overview-helpers';
import { formatDateTimeInTimezone, timezoneLabel, DEFAULT_TIMEZONE } from '@/lib/constants/timezone';
import { getSiteTimezone } from '@/lib/config/keys';
import { cn } from '@/lib/utils';
import { dsFieldClass } from '@/components/primitives/field-styles';
import Stat from '@/components/primitives/ds/Stat';

const auth = await checkAuth(Astro);
if (!auth.authenticated || !auth.user) {
  return Astro.redirect('/login');
}
const hasAccess = await userHasFeature(auth.user.id, FEATURES.ORDERS);
if (!hasAccess) {
  return Astro.redirect('/');
}

const url = new URL(Astro.request.url);
const search = (url.searchParams.get('q') || '').trim();
const statusParams = url.searchParams.getAll('status').filter(Boolean);
const dateFromStr = url.searchParams.get('from') || '';
const dateToStr = url.searchParams.get('to') || '';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10) || 1);
const perPage = 30;

const now = new Date();
const tz = await getSiteTimezone().catch(() => DEFAULT_TIMEZONE);
let data;
try {
  data = await loadOrdersListData(now);
} catch {
  data = { rows: [], kpi: EMPTY_ORDER_KPI };
}

const dateFrom = dateFromStr ? new Date(dateFromStr) : null;
const dateTo = dateToStr ? new Date(dateToStr + 'T23:59:59') : null;
const filtered = filterOrderRows(data.rows, {
  status: statusParams.length > 0 ? statusParams : undefined,
  dateFrom,
  dateTo,
  search: search || null,
});
const paged = paginate(filtered, page, perPage);

const totalDelta = computeDelta(data.kpi.total24h, data.kpi.totalPrev24h);
const paidDelta = computeDelta(data.kpi.paid24h, data.kpi.paidPrev24h);
const pendingDelta = computeDelta(data.kpi.pending24h, data.kpi.pendingPrev24h, { invertTone: true });
const refundedDelta = computeDelta(data.kpi.refunded24h, data.kpi.refundedPrev24h, { invertTone: true });

const statusOptions = ['PAID', 'PENDING', 'SHIPPED', 'DELIVERED', 'REFUNDED', 'PARTIALLY_REFUNDED'];

function pageHref(p: number): string {
  const params = new URLSearchParams(url.searchParams);
  params.set('page', String(p));
  return `/orders?${params.toString()}`;
}

function customerLabel(email: string, name: string | null): { line1: string; line2: string } {
  const trimmed = (name || '').trim();
  return { line1: email || trimmed || '—', line2: email && trimmed ? trimmed : '' };
}
---

<DashboardLayout
  title="Orders"
  activeNav="orders.orders"
>
  <a
    slot="header-actions"
    href="/api/order/export?format=csv"
    class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline"
  >
    Export CSV
  </a>

  <div class="grid grid-cols-12 gap-5">
    <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)] px-6 py-5">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <Stat
          client:load
          label="Total orders (24h)"
          value={formatNumber(data.kpi.total24h)}
          delta={{ ...totalDelta, context: 'vs prev 24h' }}
        />
        <Stat
          client:load
          label="Paid (24h)"
          value={formatNumber(data.kpi.paid24h)}
          delta={{ ...paidDelta, context: 'vs prev 24h' }}
        />
        <Stat
          client:load
          label="Pending (24h)"
          value={formatNumber(data.kpi.pending24h)}
          delta={{ ...pendingDelta, context: 'vs prev 24h' }}
        />
        <Stat
          client:load
          label="Refunded (24h)"
          value={formatNumber(data.kpi.refunded24h)}
          delta={{ ...refundedDelta, context: 'vs prev 24h' }}
        />
      </div>
    </div>

    {data.rows.length === 0 ? (
      <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)]">
        <div class="px-6 py-16 flex flex-col items-center text-center gap-3">
          <div class="w-12 h-12 rounded-full bg-ds-surface2 border border-ds-line flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-ds-muted">
              <path d="M5 7h14l-1.5 11a2 2 0 0 1-2 1.7H8.5a2 2 0 0 1-2-1.7z" />
              <path d="M9 7V5a3 3 0 0 1 6 0v2" />
            </svg>
          </div>
          <div class="text-[14px] font-semibold text-ds-ink">No orders yet</div>
          <div class="text-[12.5px] text-ds-muted max-w-[320px]">
            Orders will appear here once customers complete checkout.
          </div>
        </div>
      </div>
    ) : (
      <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)]">
        <div class="px-6 pt-5 pb-4 flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <div class="text-[14px] font-semibold text-ds-ink">All orders</div>
            <div class="text-[12.5px] text-ds-muted mt-0.5">
              <span class="font-ds-mono tabular">{paged.total}</span> matching · showing
              <span class="font-ds-mono tabular"> {paged.items.length}</span>
            </div>
          </div>
          <form method="get" action="/orders" class="flex items-center gap-2 shrink-0 flex-wrap">
            <input
              type="text"
              name="q"
              value={search}
              placeholder="Order # or email…"
              class={cn(dsFieldClass, "h-8 w-[220px]")}
            />
            <div class="relative" data-status-filter>
              <button
                type="button"
                data-status-trigger
                class="bg-ds-surface2 border border-ds-line rounded-lg px-2.5 h-8 text-[13px] text-ds-ink focus:outline-none focus:ring-2 focus:ring-ds-accent inline-flex items-center gap-1.5 min-w-[150px] justify-between"
              >
                <span data-status-label class="truncate">
                  {statusParams.length === 0
                    ? 'All statuses'
                    : statusParams.length === 1
                    ? statusParams[0].replace('_', ' ')
                    : `${statusParams.length} selected`}
                </span>
                <svg class="w-3 h-3 text-ds-muted shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5.5 7.5L10 12l4.5-4.5" />
                </svg>
              </button>
              <div
                data-status-panel
                hidden
                class="absolute z-20 top-[calc(100%+4px)] left-0 min-w-[200px] bg-ds-card border border-ds-line rounded-lg shadow-[0_8px_24px_rgba(17,24,39,.08)] py-1.5"
              >
                {statusOptions.map((s) => (
                  <label class="flex items-center gap-2 px-3 py-1.5 text-[13px] text-ds-ink hover:bg-ds-surface2 cursor-pointer">
                    <input
                      type="checkbox"
                      name="status"
                      value={s}
                      checked={statusParams.includes(s)}
                      class={cn("h-4 w-4 shrink-0 rounded-[4px] cursor-pointer accent-ds-accent")}
                    />
                    <span>{s.replace('_', ' ')}</span>
                  </label>
                ))}
              </div>
            </div>
            <input
              type="date"
              name="from"
              value={dateFromStr}
              class={cn(dsFieldClass, "h-8 w-auto")}
            />
            <input
              type="date"
              name="to"
              value={dateToStr}
              class={cn(dsFieldClass, "h-8 w-auto")}
            />
            <button
              type="submit"
              class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB]"
            >
              Filter
            </button>
          </form>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead class="bg-ds-surface2 border-b border-ds-line">
              <tr>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Status</th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Order #</th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Customer</th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">Amount</th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">Created</th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right w-[40px]"></th>
              </tr>
            </thead>
            <tbody>
              {paged.items.map((row) => {
                const cust = customerLabel(row.customerEmail, row.customerName);
                return (
                  <tr
                    class="hover:bg-ds-surface2 transition-colors cursor-pointer"
                    onclick={`window.location.href='/orders/${row.id}'`}
                  >
                    <td class="px-4 py-3 border-b border-[#F3F4F6]">
                      <span class={`inline-flex items-center gap-1.5 rounded-full border px-2 py-[3px] text-[11.5px] font-medium leading-none ${statusBadgeClasses(row.status)}`}>
                        {row.status.replace('_', ' ')}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] font-ds-mono tabular">
                      {row.orderNumber}
                    </td>
                    <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6]">
                      <div class="min-w-0">
                        <div class="text-[13.5px] text-ds-ink truncate max-w-[240px]">{cust.line1}</div>
                        {cust.line2 && (
                          <div class="text-[11.5px] text-ds-muted truncate max-w-[240px]">{cust.line2}</div>
                        )}
                      </div>
                    </td>
                    <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] text-right font-ds-mono tabular">
                      {formatMoney(row.total, row.currency)}
                    </td>
                    <td class="px-4 py-3 text-[12.5px] text-ds-muted border-b border-[#F3F4F6] text-right font-ds-mono tabular whitespace-nowrap" title={`${formatDateTimeInTimezone(row.createdAt, tz)} ${timezoneLabel(tz)}`}>
                      {relativeTime(row.createdAt, now)}
                    </td>
                    <td class="px-4 py-3 border-b border-[#F3F4F6] text-right">
                      <button
                        type="button"
                        class="text-ds-muted hover:text-ds-ink p-1"
                        onclick="event.stopPropagation();"
                        aria-label="Row actions"
                      >
                        <svg viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
                          <circle cx="3" cy="8" r="1.3" />
                          <circle cx="8" cy="8" r="1.3" />
                          <circle cx="13" cy="8" r="1.3" />
                        </svg>
                      </button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        {paged.totalPages > 1 && (
          <div class="px-6 py-3 flex items-center justify-between border-t border-ds-line bg-ds-surface2 text-[12px] text-ds-muted">
            <div>
              Showing
              <span class="font-ds-mono tabular"> {(paged.page - 1) * perPage + 1}</span>
              –
              <span class="font-ds-mono tabular">{(paged.page - 1) * perPage + paged.items.length}</span>
              of
              <span class="font-ds-mono tabular"> {paged.total}</span>
            </div>
            <div class="flex items-center gap-1">
              {paged.page > 1 ? (
                <a
                  href={pageHref(paged.page - 1)}
                  class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline"
                >
                  Prev
                </a>
              ) : (
                <span class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-faint">Prev</span>
              )}
              {pageNumbers(paged.page, paged.totalPages).map((p) =>
                p === '...' ? (
                  <span class="px-2 text-ds-faint text-[12px]">…</span>
                ) : p === paged.page ? (
                  <span class="inline-flex items-center justify-center rounded-[6px] h-7 min-w-[28px] px-2 text-[12px] bg-ds-ink text-ds-card font-ds-mono tabular">
                    {p}
                  </span>
                ) : (
                  <a
                    href={pageHref(p as number)}
                    class="inline-flex items-center justify-center rounded-[6px] h-7 min-w-[28px] px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline font-ds-mono tabular"
                  >
                    {p}
                  </a>
                ),
              )}
              {paged.page < paged.totalPages ? (
                <a
                  href={pageHref(paged.page + 1)}
                  class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline"
                >
                  Next
                </a>
              ) : (
                <span class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-faint">Next</span>
              )}
            </div>
          </div>
        )}
      </div>
    )}
  </div>

  <script>
    document.querySelectorAll<HTMLElement>('[data-status-filter]').forEach((root) => {
      const trigger = root.querySelector<HTMLButtonElement>('[data-status-trigger]');
      const panel = root.querySelector<HTMLElement>('[data-status-panel]');
      const label = root.querySelector<HTMLElement>('[data-status-label]');
      if (!trigger || !panel || !label) return;

      const updateLabel = () => {
        const checked = panel.querySelectorAll<HTMLInputElement>('input[type="checkbox"]:checked');
        if (checked.length === 0) {
          label.textContent = 'All statuses';
        } else if (checked.length === 1) {
          label.textContent = checked[0].value.replace('_', ' ');
        } else {
          label.textContent = `${checked.length} selected`;
        }
      };

      trigger.addEventListener('click', () => {
        panel.hidden = !panel.hidden;
      });

      panel.addEventListener('change', updateLabel);

      document.addEventListener('click', (event) => {
        if (!root.contains(event.target as Node)) panel.hidden = true;
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') panel.hidden = true;
      });
    });
  </script>
</DashboardLayout>
