---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, FEATURES } from '@/lib/rbac';
import DomainsPanel from '@/components/settings/DomainsPanel';
import { makeSiteConfig } from '@/composition/make-site-config';

const auth = await checkAuth(Astro);
if (!auth.authenticated || !auth.user) {
  return Astro.redirect('/login');
}
const hasAccess =
  (await userHasFeature(auth.user.id, FEATURES.SETTINGS_DOMAINS)) ||
  (await userHasFeature(auth.user.id, FEATURES.SETTINGS));
if (!hasAccess) {
  return Astro.redirect('/');
}

const rawDomains = await makeSiteConfig().domains.list().catch(() => []);
const initialDomains = rawDomains.map((d) => ({
  id: d.id,
  domain: d.host,
  isPrimary: d.isPrimary,
}));
---

<DashboardLayout
  title="Domains"
  activeNav="settings.domains"
>
  <div class="bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)] px-6 py-5">
    <DomainsPanel client:load initialDomains={initialDomains} />
  </div>
</DashboardLayout>
