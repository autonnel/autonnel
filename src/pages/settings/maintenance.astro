---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, FEATURES } from '@/lib/rbac';
import MaintenancePanel from '@/components/settings/MaintenancePanel';
import { getCurrentTenantId } from '@/lib/tenant/context';
import { getMaintenanceConfig } from '@/lib/config/keys';
import { getPolicyHooks, getUiSlot } from '@/lib/plugins/registry';

const auth = await checkAuth(Astro);
if (!auth.authenticated || !auth.user) {
  return Astro.redirect('/login');
}
const hasAccess =
  (await userHasFeature(auth.user.id, FEATURES.SETTINGS_MAINTENANCE)) ||
  (await userHasFeature(auth.user.id, FEATURES.SETTINGS));
if (!hasAccess) {
  return Astro.redirect('/');
}

const tenantId = getCurrentTenantId();
const cfg = await getMaintenanceConfig().catch(() => undefined);

const canEdit = await getPolicyHooks().canEditMaintenance({ id: tenantId });
const tooltipSlot = getUiSlot('maintenance.toggle.tooltip');
const tooltip = tooltipSlot?.entrypoint ?? null;

const initial = {
  enabled: cfg?.enabled ?? false,
  message: cfg?.message ?? '',
  hasPassword: !!cfg?.passwordHash,
  canEdit,
  tooltip,
};
---

<DashboardLayout
  title="Maintenance"
  activeNav="settings.maintenance"
>
  <div class="bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)] px-6 py-5">
    <MaintenancePanel client:load initial={initial} />
  </div>
</DashboardLayout>
