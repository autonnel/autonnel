---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, FEATURES } from '@/lib/rbac';
import ApiKeysPanel from '@/components/settings/ApiKeysPanel';
import { loadApiKeysForUser } from '@/lib/dashboard/settings-data';

const auth = await checkAuth(Astro);
if (!auth.authenticated || !auth.user) {
  return Astro.redirect('/login');
}
const hasAccess = await userHasFeature(auth.user.id, FEATURES.SETTINGS);
if (!hasAccess) {
  return Astro.redirect('/');
}

function maskKey(key: string): string {
  if (!key) return '';
  if (key.length <= 10) return key;
  return `${key.slice(0, 6)}…${key.slice(-4)}`;
}

const rawKeys = await loadApiKeysForUser(auth.user.id);
const initialKeys = rawKeys.map((k) => ({
  id: k.id,
  name: k.name,
  key: maskKey(k.key),
  writeAccess: k.writeAccess,
  isActive: k.isActive,
  expiresAt: k.expiresAt ? k.expiresAt.toISOString() : null,
  createdAt: k.createdAt.toISOString(),
}));
---

<DashboardLayout
  title="API Keys"
  activeNav="settings.api-keys"
>
  <div class="bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)] px-6 py-5">
    <ApiKeysPanel client:load initialKeys={initialKeys} />
  </div>
</DashboardLayout>
