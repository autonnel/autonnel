---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, FEATURES } from '@/lib/rbac';
import { FunnelSteps } from '@/components/funnel';
import { DB_TO_FUNNEL_PAGE_TYPE } from '@/components/funnel/types';
import { getTenantPrisma } from '@/modules/platform/infra/prisma-tenant-extension';
import { getFunnelValidationErrors } from '@/lib/funnel-validator';
import { loadFunnelViewUrl } from '@/lib/dashboard/funnels-data';

const auth = await checkAuth(Astro);

if (!auth.authenticated || !auth.user) {
  return Astro.redirect('/login');
}

const hasAccess = await userHasFeature(auth.user.id, FEATURES.FUNNELS);
if (!hasAccess) {
  return Astro.redirect('/');
}

const { funnelId } = Astro.params;
const prisma = getTenantPrisma();

interface FunnelStepJson {
  stepSlug?: string;
  pageId?: string;
  nextUrl?: string | null;
}

interface PageRow {
  id: string;
  name: string;
  slug: string;
  type: string;
  status: string;
}

function stepsOf(raw: unknown): FunnelStepJson[] {
  return Array.isArray(raw) ? (raw as FunnelStepJson[]) : [];
}

const funnel = await (prisma.funnel.findFirst({
  where: { id: funnelId },
  select: { id: true, name: true, description: true, steps: true, createdAt: true, updatedAt: true },
}) as Promise<{ id: string; name: string; description: string | null; steps: unknown; createdAt: Date; updatedAt: Date } | null>);

if (!funnel) {
  return new Response('Funnel not found', { status: 404 });
}

const steps = stepsOf(funnel.steps);

const allPages = await (prisma.page.findMany({
  select: { id: true, name: true, slug: true, type: true, status: true },
  orderBy: { name: 'asc' },
}) as Promise<PageRow[]>);

const pageById = new Map<string, PageRow>(allPages.map((p) => [p.id, p]));

const enrichedPages = steps.map((step, i) => {
  const pageId = step.pageId ?? '';
  const page = pageById.get(pageId);
  const dbType = (page?.type ?? 'custom').toUpperCase();
  return {
    id: pageId || `step-${i}`,
    pageId,
    pageType: DB_TO_FUNNEL_PAGE_TYPE[dbType] ?? 'LANDING',
    order: i,
    subOrder: 0,
    stepSlug: step.stepSlug ?? null,
    nextUrl: step.nextUrl ?? null,
    page,
  };
});

const enrichedFunnel = {
  id: funnel.id,
  name: funnel.name,
  slug: funnel.id,
  description: funnel.description,
  createdAt: funnel.createdAt.toISOString(),
  updatedAt: funnel.updatedAt.toISOString(),
  pages: enrichedPages,
};

const otherFunnels = await (prisma.funnel.findMany({
  where: { id: { not: funnelId } },
  select: { name: true, steps: true },
}) as Promise<Array<{ name: string; steps: unknown }>>);

const boundPageIds = new Map<string, string>();
for (const other of otherFunnels) {
  const otherSteps = stepsOf(other.steps);
  const landingPageId = otherSteps[0]?.pageId;
  if (landingPageId) boundPageIds.set(landingPageId, other.name);
}

const validationErrors = await getFunnelValidationErrors(funnelId!);

const viewUrl = await loadFunnelViewUrl(funnelId!);

const tabs = [
  { id: 'overview', label: 'Overview', href: `/funnel/${funnelId}` },
  { id: 'pages', label: 'Pages', href: `/funnel/${funnelId}/pages` },
  { id: 'analytics', label: 'Analytics', href: `/funnel/${funnelId}/analytics` },
  { id: 'marketing', label: 'Marketing', href: `/funnel/${funnelId}/marketing` },
  { id: 'experiment', label: 'Experiment', href: `/funnel/${funnelId}/experiment` },
  { id: 'custom-code', label: 'Custom Code', href: `/funnel/${funnelId}/custom-code` },
  { id: 'settings', label: 'Settings', href: `/funnel/${funnelId}/settings` },
];
const activeTab = 'pages';
---

<DashboardLayout
  title={funnel.name}
  activeNav="funnels.funnels"
  breadcrumbs={[
    { label: 'Autonnel', href: '/' },
    { label: 'Funnels', href: '/funnels' },
    { label: funnel.name, href: `/funnel/${funnelId}` },
    { label: 'Pages' },
  ]}
>
  <a
    slot="header-actions"
    href={`/funnel/${funnelId}`}
    class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline"
  >
    Overview
  </a>
  {viewUrl && (
    <a
      slot="header-actions"
      href={viewUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline"
    >
      View
    </a>
  )}

  <div class="-mt-2 mb-5 border-b border-ds-line">
    <nav class="flex items-center gap-1 overflow-x-auto" aria-label="Funnel sections">
      {tabs.map((t) => {
        const active = t.id === activeTab;
        const cls = active
          ? 'inline-flex items-center px-3 py-2.5 text-[13px] font-medium text-ds-ink border-b-2 border-ds-ink no-underline'
          : 'inline-flex items-center px-3 py-2.5 text-[13px] font-medium text-ds-muted hover:text-ds-ink border-b-2 border-transparent no-underline';
        return (
          <a href={t.href} class={cls}>
            {t.label}
          </a>
        );
      })}
    </nav>
  </div>

  <FunnelSteps
    client:load
    funnel={enrichedFunnel}
    allPages={allPages}
    validationErrors={validationErrors}
    boundPageIds={Object.fromEntries(boundPageIds)}
  />
</DashboardLayout>
