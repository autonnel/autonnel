---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { checkAuth } from '@/lib/auth/middleware';
import { userHasFeature, FEATURES } from '@/lib/rbac';
import { loadFunnelsListData } from '@/lib/dashboard/funnels-data';
import {
  sortFunnelList,
  paginate,
  pageNumbers,
  type FunnelListSortKey,
  type FunnelListSortOrder,
} from '@/lib/dashboard/funnels-helpers';
import { computeDelta, formatNumber } from '@/lib/dashboard/overview-helpers';
import { cn } from '@/lib/utils';
import { dsFieldClass } from '@/components/primitives/field-styles';
import Stat from '@/components/primitives/ds/Stat';
import SparkLine from '@/components/primitives/ds/SparkLine';
import NewFunnelModal from '@/components/funnels/NewFunnelModal';

const auth = await checkAuth(Astro);
if (!auth.authenticated || !auth.user) {
  return Astro.redirect('/login');
}
const hasAccess = await userHasFeature(auth.user.id, FEATURES.FUNNELS);
if (!hasAccess) {
  return Astro.redirect('/');
}

const url = new URL(Astro.request.url);
const search = (url.searchParams.get('q') || '').trim().toLowerCase();
const sortKey = ((url.searchParams.get('sort') as FunnelListSortKey) || 'visits');
const sortOrder = ((url.searchParams.get('order') as FunnelListSortOrder) || 'desc');
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10) || 1);
const perPage = 20;

const now = new Date();
let data;
try {
  data = await loadFunnelsListData(now);
} catch {
  data = {
    rows: [],
    totals: { activeFunnels: 0, visits24h: 0, convPct: 0, convPctPrev: 0 },
    visits24hSpark: [],
    conv24hSpark: [],
  };
}

const filtered = search
  ? data.rows.filter((r) => r.name.toLowerCase().includes(search) || r.id.toLowerCase().includes(search))
  : data.rows;
const sorted = sortFunnelList(filtered, sortKey, sortOrder);
const paged = paginate(sorted, page, perPage);

const convDelta = computeDelta(data.totals.convPct, data.totals.convPctPrev);

function dotStyle(status: 'ok' | 'warn' | 'bad' | 'muted') {
  const map = {
    ok: { bg: '#16A34A', ring: 'rgba(22,163,74,0.12)' },
    warn: { bg: '#D97706', ring: 'rgba(217,119,6,0.12)' },
    bad: { bg: '#DC2626', ring: 'rgba(220,38,38,0.12)' },
    muted: { bg: '#9CA3AF', ring: 'rgba(156,163,175,0.12)' },
  } as const;
  const { bg, ring } = map[status];
  return `background-color: ${bg}; box-shadow: 0 0 0 3px ${ring};`;
}

function sortHref(key: FunnelListSortKey): string {
  const params = new URLSearchParams(url.searchParams);
  const nextOrder = sortKey === key && sortOrder === 'desc' ? 'asc' : 'desc';
  params.set('sort', key);
  params.set('order', nextOrder);
  params.delete('page');
  return `/funnels?${params.toString()}`;
}

function pageHref(p: number): string {
  const params = new URLSearchParams(url.searchParams);
  params.set('page', String(p));
  return `/funnels?${params.toString()}`;
}

function sortIndicator(key: FunnelListSortKey): string {
  if (sortKey !== key) return '';
  return sortOrder === 'asc' ? ' ↑' : ' ↓';
}
---

<DashboardLayout
  title="Funnels"
  activeNav="funnels.funnels"
>
  <a
    slot="header-actions"
    href="/funnels?new=1"
    onclick="event.preventDefault(); window.dispatchEvent(new CustomEvent('autonnel:new-funnel'));"
    class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-ink border border-ds-ink text-ds-card hover:bg-[#1F2937] no-underline"
  >
    + New funnel
  </a>

  <div class="grid grid-cols-12 gap-5">
    <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)] px-6 py-5">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <Stat
          client:load
          label="Active funnels"
          value={formatNumber(data.totals.activeFunnels)}
          sparkline={[]}
        />
        <Stat
          client:load
          label="24h aggregate traffic"
          value={formatNumber(data.totals.visits24h)}
          sparkline={data.visits24hSpark}
          sparklineColor="#2563EB"
        />
        <Stat
          client:load
          label="24h conversion rate"
          value={`${data.totals.convPct.toFixed(2)}%`}
          delta={{ ...convDelta, context: 'vs prev 24h' }}
          sparkline={data.conv24hSpark}
          sparklineColor="#16A34A"
        />
      </div>
    </div>

    {data.rows.length === 0 ? (
      <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)]">
        <div class="px-6 py-16 flex flex-col items-center text-center gap-3">
          <div class="w-12 h-12 rounded-full bg-ds-surface2 border border-ds-line flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-6 h-6 text-ds-muted">
              <path d="M3 4h18l-7 8v6l-4 2v-8z" />
            </svg>
          </div>
          <div class="text-[14px] font-semibold text-ds-ink">No funnels yet</div>
          <div class="text-[12.5px] text-ds-muted max-w-[320px]">
            Create your first funnel to start measuring conversions across your sites.
          </div>
          <a
            href="/funnels?new=1"
            onclick="event.preventDefault(); window.dispatchEvent(new CustomEvent('autonnel:new-funnel'));"
            class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-ink border border-ds-ink text-ds-card hover:bg-[#1F2937] no-underline mt-2"
          >
            + Create funnel
          </a>
        </div>
      </div>
    ) : (
      <div class="col-span-12 bg-ds-card border border-ds-line rounded-[10px] shadow-[0_1px_2px_rgba(17,24,39,.04)]">
        <div class="px-6 pt-5 pb-4 flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <div class="text-[14px] font-semibold text-ds-ink">All funnels</div>
            <div class="text-[12.5px] text-ds-muted mt-0.5">
              <span class="font-ds-mono tabular">{paged.total}</span> total · showing
              <span class="font-ds-mono tabular"> {paged.items.length}</span>
            </div>
          </div>
          <form method="get" action="/funnels" class="flex items-center gap-2 shrink-0">
            <input type="hidden" name="sort" value={sortKey} />
            <input type="hidden" name="order" value={sortOrder} />
            <input
              type="text"
              name="q"
              value={search}
              placeholder="Search by name or slug…"
              class={cn(dsFieldClass, "h-8 w-[260px]")}
            />
            <button
              type="submit"
              class="inline-flex items-center justify-center font-medium rounded-[7px] h-8 px-3 text-[13px] gap-2 bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB]"
            >
              Search
            </button>
          </form>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full border-collapse">
            <thead class="bg-ds-surface2 border-b border-ds-line">
              <tr>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left w-[40px]"></th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">
                  <a href={sortHref('name')} class="text-ds-muted no-underline hover:text-ds-ink">Funnel{sortIndicator('name')}</a>
                </th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-left">Funnel URL</th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">
                  <a href={sortHref('pageCount')} class="text-ds-muted no-underline hover:text-ds-ink">Pages{sortIndicator('pageCount')}</a>
                </th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">
                  <a href={sortHref('visits')} class="text-ds-muted no-underline hover:text-ds-ink">24h Traffic{sortIndicator('visits')}</a>
                </th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">
                  <a href={sortHref('orders')} class="text-ds-muted no-underline hover:text-ds-ink">24h Orders{sortIndicator('orders')}</a>
                </th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">
                  <a href={sortHref('conv')} class="text-ds-muted no-underline hover:text-ds-ink">Conv{sortIndicator('conv')}</a>
                </th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right">7d trend</th>
                <th class="px-4 py-2.5 text-[11.5px] uppercase tracking-[0.02em] font-medium text-ds-muted text-right w-[40px]"></th>
              </tr>
            </thead>
            <tbody>
              {paged.items.map((row) => (
                <tr
                  class="hover:bg-ds-surface2 transition-colors cursor-pointer"
                  onclick={`window.location.href='/funnel/${row.id}'`}
                >
                  <td class="px-4 py-3 border-b border-[#F3F4F6]">
                    <span
                      class="inline-block w-[7px] h-[7px] rounded-full shrink-0"
                      style={dotStyle(row.status)}
                      aria-hidden="true"
                    ></span>
                  </td>
                  <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6]">
                    <div class="min-w-0">
                      <div class="flex items-center gap-2 min-w-0">
                        <span class="text-[13.5px] text-ds-ink truncate">{row.name}</span>
                        {!row.hasErrorPage && (
                          <span
                            class="inline-flex items-center gap-1 rounded-full border px-2 py-[2px] text-[11px] font-medium leading-none bg-ds-warnBg border-ds-warnBorder text-ds-warnText shrink-0"
                            title="Create an error page so customers see a friendly fallback when payment fails."
                          >
                            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="w-3 h-3" aria-hidden="true">
                              <path d="M8 5v4M8 11v.01M8 1.5l6.5 11.5h-13L8 1.5z" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            No error page
                          </span>
                        )}
                      </div>
                      <div class="text-[11.5px] text-ds-muted font-ds-mono tabular truncate">{row.id}</div>
                    </div>
                  </td>
                  <td class="px-4 py-3 border-b border-[#F3F4F6]">
                    {row.publicUrl ? (
                      <a
                        href={row.publicUrl}
                        target="_blank"
                        rel="noopener"
                        onclick="event.stopPropagation();"
                        class="block max-w-[280px] truncate text-[12.5px] text-ds-accent hover:underline font-ds-mono tabular"
                        title={row.publicUrl}
                      >
                        {row.publicUrl}
                      </a>
                    ) : (
                      <span class="text-[11.5px] text-ds-faint font-ds-mono">—</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] text-right font-ds-mono tabular">
                    {row.pageCount}
                  </td>
                  <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] text-right font-ds-mono tabular">
                    {row.visits24h.toLocaleString()}
                  </td>
                  <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] text-right font-ds-mono tabular">
                    {row.orders24h.toLocaleString()}
                  </td>
                  <td class="px-4 py-3 text-[13.5px] text-ds-ink border-b border-[#F3F4F6] text-right font-ds-mono tabular">
                    {row.conv}
                  </td>
                  <td class="px-4 py-3 border-b border-[#F3F4F6] text-right">
                    <div class="inline-block">
                      {row.trend.some((t) => t > 0) ? (
                        <SparkLine client:load points={row.trend} color="#2563EB" width={80} height={20} />
                      ) : (
                        <span class="text-[11.5px] text-ds-faint font-ds-mono">—</span>
                      )}
                    </div>
                  </td>
                  <td class="px-4 py-3 border-b border-[#F3F4F6] text-right">
                    <button
                      type="button"
                      class="text-ds-muted hover:text-ds-ink p-1"
                      onclick="event.stopPropagation();"
                      aria-label="Row actions"
                    >
                      <svg viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
                        <circle cx="3" cy="8" r="1.3" />
                        <circle cx="8" cy="8" r="1.3" />
                        <circle cx="13" cy="8" r="1.3" />
                      </svg>
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {paged.totalPages > 1 && (
          <div class="px-6 py-3 flex items-center justify-between border-t border-ds-line bg-ds-surface2 text-[12px] text-ds-muted">
            <div>
              Showing
              <span class="font-ds-mono tabular"> {(paged.page - 1) * perPage + 1}</span>
              –
              <span class="font-ds-mono tabular">{(paged.page - 1) * perPage + paged.items.length}</span>
              of
              <span class="font-ds-mono tabular"> {paged.total}</span>
            </div>
            <div class="flex items-center gap-1">
              {paged.page > 1 ? (
                <a
                  href={pageHref(paged.page - 1)}
                  class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline"
                >
                  Prev
                </a>
              ) : (
                <span class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-faint">Prev</span>
              )}
              {pageNumbers(paged.page, paged.totalPages).map((p) =>
                p === '...' ? (
                  <span class="px-2 text-ds-faint text-[12px]">…</span>
                ) : p === paged.page ? (
                  <span class="inline-flex items-center justify-center rounded-[6px] h-7 min-w-[28px] px-2 text-[12px] bg-ds-ink text-ds-card font-ds-mono tabular">
                    {p}
                  </span>
                ) : (
                  <a
                    href={pageHref(p as number)}
                    class="inline-flex items-center justify-center rounded-[6px] h-7 min-w-[28px] px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline font-ds-mono tabular"
                  >
                    {p}
                  </a>
                ),
              )}
              {paged.page < paged.totalPages ? (
                <a
                  href={pageHref(paged.page + 1)}
                  class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-ink hover:bg-[#F9FAFB] no-underline"
                >
                  Next
                </a>
              ) : (
                <span class="inline-flex items-center justify-center rounded-[6px] h-7 px-2 text-[12px] bg-ds-card border border-ds-line text-ds-faint">Next</span>
              )}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
  <NewFunnelModal client:load />
</DashboardLayout>
