{
  "name": "autonnel",
  "version": "1.3.1",
  "description": "Autonnel - Open-source AI-native funnel builder for e-commerce",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/autonnel/autonnel.git"
  },
  "homepage": "https://autonnel.com",
  "bugs": {
    "url": "https://github.com/autonnel/autonnel/issues"
  },
  "type": "module",
  "main": "./dist/integration/index.js",
  "bin": {
    "autonnel": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/integration/index.d.ts",
      "import": "./dist/integration/index.js"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    },
    "./api": {
      "types": "./dist/lib/api/guard.d.ts",
      "import": "./dist/lib/api/guard.js"
    },
    "./adapters/*": {
      "import": "./dist/lib/adapters/*/index.js"
    },
    "./schema": "./prisma/schema.prisma",
    "./hooks": {
      "types": "./dist/lib/hooks/index.d.ts",
      "import": "./dist/lib/hooks/index.js"
    },
    "./tenant": {
      "types": "./dist/lib/tenant/index.d.ts",
      "import": "./dist/lib/tenant/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./identity": {
      "types": "./dist/integration/consumer-identity.d.ts",
      "import": "./dist/integration/consumer-identity.js"
    },
    "./cf-worker": "./src/cf-worker.ts",
    "./pages/*": "./src/pages/*",
    "./components/*": "./src/components/*",
    "./lib/permissions": {
      "types": "./dist/lib/rbac/index.d.ts",
      "import": "./dist/lib/rbac/index.js"
    },
    "./lib/adapters/cache": {
      "types": "./dist/lib/adapters/cache/index.d.ts",
      "import": "./dist/lib/adapters/cache/index.js"
    },
    "./lib/adapters/payment": {
      "types": "./dist/lib/adapters/payment/index.d.ts",
      "import": "./dist/lib/adapters/payment/index.js"
    },
    "./lib/adapters/ads": {
      "types": "./dist/lib/adapters/ads/index.d.ts",
      "import": "./dist/lib/adapters/ads/index.js"
    },
    "./lib/adapters/mq": {
      "types": "./dist/lib/adapters/mq/index.d.ts",
      "import": "./dist/lib/adapters/mq/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./layouts/*": "./src/layouts/*",
    "./styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "!dist/client",
    "!dist/server",
    "!dist/**/*.map",
    "prisma/schema.prisma",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/__tests__/**",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "astro": ">=6.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": false },
    "react-dom": { "optional": false }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.11.1",
  "keywords": [
    "funnel",
    "checkout",
    "ecommerce",
    "astro",
    "stripe",
    "paypal",
    "shopify",
    "woocommerce",
    "resend"
  ],
  "scripts": {
    "clean:cache": "node scripts/clean-cache.mjs",
    "dev": "npm run clean:cache && npx prisma generate && astro dev",
    "build": "npx prisma generate && astro build && node scripts/build-package.mjs",
    "start": "node ./dist/server/entry.mjs",
    "build:package": "node scripts/build-package.mjs",
    "prepublishOnly": "npm run build:package",
    "generate:wrangler": "node scripts/generate-wrangler.mjs",
    "build:cf": "node scripts/build-cf.mjs",
    "dev:cf": "npm run clean:cache && npx prisma generate && astro dev --config astro.config.cloudflare.mjs",
    "preview:cf": "npm run build:cf && wrangler dev",
    "deploy:cf": "npm run build:cf && wrangler deploy",
    "db:push": "npx prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:payments": "vitest run src/modules/payments --coverage --config vitest.payments.config.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/openai": "^3.0.54",
    "@arco-design/web-react": "^2.66.15",
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/node": "^10.1.4",
    "@astrojs/react": "^5.0.7",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@puckeditor/core": "0.21.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "ai": "^6.0.182",
    "aws4fetch": "^1.0.20",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "easy-email-core": "^4.16.5",
    "easy-email-editor": "^4.16.6",
    "easy-email-extensions": "^4.16.5",
    "grapesjs": "^0.22.4",
    "grapesjs-blocks-basic": "^1.0.2",
    "grapesjs-preset-webpage": "^1.0.3",
    "ioredis": "^5.9.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "mjml-browser": "^4.18.0",
    "monaco-editor": "^0.52.2",
    "p-limit": "^6.2.0",
    "pg": "^8.16.3",
    "prisma": "^7.1.0",
    "react-final-form": "^6.5.9",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.4",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^6.4.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.107.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.14",
      "@puckeditor/core>uuid": "11.1.1",
      "easy-email-core>uuid": "11.1.1",
      "easy-email-extensions>uuid": "11.1.1",
      "js-cookie": "3.0.7"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "workerd"
    ]
  }
}
